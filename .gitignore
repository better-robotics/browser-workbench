# macOS
.DS_Store

# Arduino build output
/tmp/
build/
*.hex
*.elf
*.bin
*.map

# ...except the published firmware bins, which are deployed to Pages.
# ** to cover the per-board sub-directories (aithinker_cam/, devkit/,
# c3_supermini/, …) — single-star globs only re-allow at one depth and
# silently dropped the multi-board bins from CI commits.
!public/firmware/bins/**/*.bin

# Local config
config.mk
.env
*.local

# Editors
.vscode/
.idea/
*.swp
firmware/esp32_robot_idf/main/version.h
.claude/scheduled_tasks.lock
