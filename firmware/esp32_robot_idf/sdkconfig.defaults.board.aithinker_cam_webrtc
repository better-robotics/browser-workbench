# AI-Thinker ESP32-CAM + WebRTC video. Delta from board.aithinker_cam —
# build.sh composes both overlays:
#   SDKCONFIG_DEFAULTS="sdkconfig.defaults
#                       ;sdkconfig.defaults.board.aithinker_cam
#                       ;sdkconfig.defaults.board.aithinker_cam_webrtc"
# ~215 KB heavier image than the MJPEG-only sibling.
CONFIG_BR_WEBRTC_ESP_PEER=y

# mbedTLS bits libpeer's DTLS-SRTP handshake needs. Set explicitly here
# rather than via Kconfig `select` chain on BR_WEBRTC_ESP_PEER — the chain
# wasn't reliably propagating in the multi-overlay setup (root cause
# unclear; the same select chain works in single-defaults setups).
# MBEDTLS_X509_CREATE_C and MBEDTLS_CIPHER_MODE_CTR are defined
# unconditionally by esp-idf's mbedtls/port config — nothing to set.
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_SSL_DTLS_SRTP=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA=y
CONFIG_MBEDTLS_ECDH_C=y
CONFIG_MBEDTLS_ECDSA_C=y
CONFIG_MBEDTLS_ECP_DP_SECP256R1_ENABLED=y
CONFIG_MBEDTLS_GCM_C=y
CONFIG_MBEDTLS_SHA1_C=y
CONFIG_MBEDTLS_HKDF_C=y
