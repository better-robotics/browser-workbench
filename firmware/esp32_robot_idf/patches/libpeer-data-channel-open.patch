# Patch sepfy/libpeer (commit 9319aa434cb9) to register the SCTP
# label→sid mapping for offer-initiated data channels under
# CONFIG_USE_USRSCTP.
#
# Bug: sctp_handle_incoming_data dispatches DATA_CHANNEL_PPID_CONTROL
# to a no-op `break`, so DATA_CHANNEL_OPEN messages are silently
# dropped. peer_connection_lookup_sid_label() then returns NULL for
# every received message and on_dc_message can't dispatch by label.
#
# Mirrors what the non-usrsctp path already does in sctp_handle_sctp_packet.
# TODO: open a PR upstream at sepfy/libpeer.
#
# Apply (idempotent — `patch` skips on second run):
#   patch -p3 -d managed_components/libpeer/src \
#       --forward --silent --batch < patches/libpeer-data-channel-open.patch \
#       || true
#
--- a/managed_components/libpeer/src/sctp.c
+++ b/managed_components/libpeer/src/sctp.c
@@ -417,6 +417,12 @@ static int sctp_handle_incoming_data(Sctp* sctp, char* data, size_t len, uint32_
 #if CONFIG_USE_USRSCTP
   switch (ppid) {
     case DATA_CHANNEL_PPID_CONTROL:
+      // LOCAL PATCH: DATA_CHANNEL_OPEN messages arrive on the CONTROL
+      // PPID and need to register the label→sid mapping in stream_table.
+      // Without this, peer_connection_lookup_sid_label() returns NULL
+      // for every offer-initiated channel and on_dc_message can't
+      // dispatch by label.
+      sctp_parse_data_channel_open(sctp, sid, data, len);
       break;
 
     case DATA_CHANNEL_PPID_DOMSTRING:
