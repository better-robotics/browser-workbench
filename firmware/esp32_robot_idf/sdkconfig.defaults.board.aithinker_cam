# AI-Thinker ESP32-CAM — classic ESP32 with OV2640/OV3660 camera, 4 MB
# SPI PSRAM, camera streams over HTTP MJPEG. The "headline" board.
CONFIG_BR_BOARD_AITHINKER_CAM=y

# Classic ESP32 max — 240 MHz is a free linear speedup over the IDF
# 160 MHz default; camera JPEG encode + WiFi/BLE coex both benefit.
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

CONFIG_ESP32_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# Push allocations to PSRAM by default. mbedTLS contexts (HTTPS OTA),
# NimBLE non-critical state — none of these need internal-only RAM.
# Default threshold (16 KB) keeps everything <16 KB internal, which fragments
# the heap and starves the camera DMA's 32 KB contiguous request.
# - ALWAYSINTERNAL=256 — only allocations <256 B forced internal (small,
#   high-frequency stuff like task control blocks).
# - RESERVE_INTERNAL=32768 — keep 32 KB internal headroom unused by PSRAM-
#   capable callers, so the camera's MALLOC_CAP_INTERNAL+CAP_DMA call
#   always finds its block.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=256
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# esp32-camera component knobs — present here so non-camera boards (which
# don't include esp32-camera in PRIV_REQUIRES) don't trip "unknown CONFIG"
# warnings on Kconfig load.
CONFIG_CAMERA_TASK_STACK_SIZE=4096

# AI-Thinker boards often ship with Boya flash chips; generic driver works
# but the Boya-specific one has tuned read/write timings.
CONFIG_SPI_FLASH_SUPPORT_BOYA_CHIP=y
