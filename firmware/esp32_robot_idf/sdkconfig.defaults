# Defaults applied on first build to every board. Board-specific overrides
# live in sdkconfig.defaults.board.<name>, layered on top via build.sh:
#   SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.board.<name>"
# Not named sdkconfig.defaults.<target> because two boards share IDF_TARGET
# esp32 (AI-Thinker CAM, DevKitV1) — auto-target-overlay would apply the
# wrong file to one of them.

CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# CPU clock is set per-board: classic ESP32 can run 240, C3 maxes at 160.

# Logging — IDF v5.5 disabled colors by default; restore them so the
# recovery console renders I/W/E lines green/yellow/red.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_COLORS=y
CONFIG_BOOTLOADER_LOG_COLORS=y

# Bluetooth (NimBLE — matches Arduino stack)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=n
CONFIG_BT_BLUEDROID_ENABLED=n
# Single dashboard at a time. Pair-mailbox (Phase 2.F.2 BLE-relay) was
# why this was 4 and CCCDs were 32; with that gone, 2 connections is
# enough headroom for "operator's dashboard + a brief overlap during
# refresh". CCCDs = 2 conns × ~10 notify-capable chars, with margin.
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=2
CONFIG_BT_NIMBLE_MAX_CCCDS=24

# Networking — buffer sizes tuned during the (since-removed) WebRTC/libpeer
# era for SCTP + video-frame UDP bursts. Left in place: they haven't caused
# problems for HTTP MJPEG or BLE OTA, and re-tuning without a WebRTC-shaped
# workload to validate against would be guessing. Revisit if flash/heap
# budget pressure calls for reclaiming this headroom.
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_LWIP_UDP_RECVMBOX_SIZE=8
CONFIG_LWIP_PBUF_POOL_SIZE=16

# IPv6. On apartment-WiFi-as-a-service the IPv4 path goes through a
# centralized gateway that adds 100-300 ms to lateral traffic between
# residents — but the ISP delegates each device a global IPv6 address,
# and IPv6 packets between devices on the same /64 route directly via
# neighbor discovery. Enabling v6 lets any peer-to-peer LAN traffic pair
# host-v6↔host-v6, bypassing the slow v4 NAT entirely.
CONFIG_LWIP_IPV6=y
CONFIG_LWIP_IPV6_AUTOCONFIG=y
# DHCPv6 stateless. WhiteSky-Beckon (and likely other apt-WiFi) doesn't
# auto-send RAs to non-Apple clients via SLAAC, but does run a DHCPv6
# server. Phones get global v6 because Apple stacks do DHCPv6 by default.
CONFIG_LWIP_IPV6_DHCP6=y

# mbedTLS — hardware AES/SHA always on (free on this chip, used by both
# WiFi WPA and any future TLS).
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y

# Trim mbedTLS record buffers from the 16 KiB default to save internal
# heap that feeds the camera DMA's 32 KiB contiguous request.
CONFIG_MBEDTLS_ASYMMETRIC_CONTENT_LEN=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=2048
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=1500

# Partition table — OTA needs two app slots + factory.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
