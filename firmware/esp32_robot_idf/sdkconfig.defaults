# Defaults applied on first build (idf.py reconfigure regenerates sdkconfig
# from these). Per-target overrides go in sdkconfig.defaults.<target>.

# WebRTC needs network + SCTP-friendly LWIP buffer sizes. Camera + NimBLE
# both want PSRAM. PSRAM mode is set per-target since classic ESP32 uses
# external SPI PSRAM and S3 uses Octal PSRAM.

# Logging — IDF v5.5 disabled colors by default; restore them so the
# recovery console renders I/W/E lines green/yellow/red.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_COLORS=y
CONFIG_BOOTLOADER_LOG_COLORS=y

# Bluetooth (NimBLE — matches Arduino stack)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=n
CONFIG_BT_BLUEDROID_ENABLED=n
# Single dashboard at a time. Pair-mailbox (Phase 2.F.2 BLE-relay) was
# why this was 4 and CCCDs were 32; with that gone, 2 connections is
# enough headroom for "operator's dashboard + a brief overlap during
# refresh". CCCDs = 2 conns × ~10 notify-capable chars, with margin.
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=2
CONFIG_BT_NIMBLE_MAX_CCCDS=24

# Networking — bigger LWIP buffers help SCTP throughput on data channels.
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384
# UDP send-side: libpeer's video-frame sends spammed "sendto: ENOMEM"
# on classic ESP32 with default WiFi TX buffers. Doubling the dynamic
# tx pool + raising the lwIP pbuf pool from 10→32 gives the WiFi TX
# path room to drain JPEG bursts without ENOMEM cascades. The video
# pump also chunks at ~900 B with a 2ms delay between chunks so the
# producer paces the consumer; this just adds headroom.
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=64
CONFIG_LWIP_UDP_RECVMBOX_SIZE=16
CONFIG_LWIP_PBUF_POOL_SIZE=32

# IPv6. On apartment-WiFi-as-a-service the IPv4 path goes through a
# centralized gateway that adds 100-300 ms to lateral traffic between
# residents — but the ISP delegates each device a global IPv6 address,
# and IPv6 packets between devices on the same /64 route directly via
# neighbor discovery. Enabling v6 lets WebRTC ICE pair host-v6↔host-v6,
# bypassing the slow v4 NAT entirely.
CONFIG_LWIP_IPV6=y
CONFIG_LWIP_IPV6_AUTOCONFIG=y
# DHCPv6 stateless. WhiteSky-Beckon (and likely other apt-WiFi) doesn't
# auto-send RAs to non-Apple clients via SLAAC, but does run a DHCPv6
# server. Phones get global v6 because Apple stacks do DHCPv6 by default.
CONFIG_LWIP_IPV6_DHCP6=y

# mbedTLS — libpeer needs DTLS; default subset usually works but be explicit
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y
# Mozilla root CA bundle — wss://signal.neevs.io needs server cert verification
# without us shipping a per-host PEM in flash.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# Route mbedTLS allocations to SPIRAM. Tried disabling for speed (DRAM
# is 4-8× faster), but esp-x509-crt-bundle started returning
# PK_TYPE_MISMATCH (-0x10) verifying proxy.neevs.io's ECDSA chain when
# the bundle/cert lived in DRAM. PSRAM-allocated path was the working
# config; libpeer's DTLS handshake was the slow part anyway, not the
# bundle decode. Net: keep mbedTLS in PSRAM, eat the modest crypto
# speed cost, regain working HTTPS.
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y

# Camera framebuffer in PSRAM
CONFIG_CAMERA_TASK_STACK_SIZE=4096

# Partition table — OTA needs two app slots + factory.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
